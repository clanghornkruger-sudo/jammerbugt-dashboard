<!DOCTYPE html>
<html lang="da">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Jammerbugt Open 2026 — Live Dashboard</title>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Bebas+Neue&family=DM+Sans:wght@400;500;600;700&family=JetBrains+Mono:wght@400;700&display=swap" rel="stylesheet">
<style>
  :root {
    --bg-dark: #0a0e1a;
    --bg-card: #131826;
    --bg-card-hover: #1a2030;
    --border: #232a3d;
    --text: #e8ecf4;
    --text-dim: #8892a8;
    --text-faint: #4a5168;
    --hvid: #f4f4f4;
    --hvid-accent: #d4d4d4;
    --rod: #d63240;
    --rod-deep: #a3232f;
    --gold: #d4a64a;
    --gold-bright: #f0c060;
    --green: #4ade80;
    --shadow: 0 8px 32px rgba(0,0,0,0.4);
    --display: 'Bebas Neue', sans-serif;
    --body: 'DM Sans', sans-serif;
    --mono: 'JetBrains Mono', monospace;
  }

  * { box-sizing: border-box; margin: 0; padding: 0; }

  body {
    font-family: var(--body);
    background: var(--bg-dark);
    background-image:
      radial-gradient(at 20% 0%, rgba(214, 50, 64, 0.08) 0%, transparent 50%),
      radial-gradient(at 80% 100%, rgba(212, 166, 74, 0.06) 0%, transparent 50%);
    color: var(--text);
    min-height: 100vh;
    padding: 24px;
    line-height: 1.5;
  }

  .container { max-width: 1400px; margin: 0 auto; }

  /* HEADER */
  .header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: 32px;
    padding-bottom: 20px;
    border-bottom: 1px solid var(--border);
  }
  .title h1 {
    font-family: var(--display);
    font-size: 56px;
    line-height: 1;
    letter-spacing: 0.02em;
    color: var(--text);
  }
  .title h1 .accent { color: var(--gold); }
  .title .subtitle {
    font-family: var(--mono);
    font-size: 11px;
    color: var(--text-dim);
    text-transform: uppercase;
    letter-spacing: 0.2em;
    margin-top: 6px;
  }
  .header-right { display: flex; align-items: center; gap: 16px; }
  .last-update {
    font-family: var(--mono);
    font-size: 11px;
    color: var(--text-dim);
    text-align: right;
  }
  .last-update strong { color: var(--text); }
  .refresh-btn {
    background: var(--gold);
    color: var(--bg-dark);
    border: none;
    padding: 12px 24px;
    font-family: var(--body);
    font-weight: 700;
    font-size: 13px;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    cursor: pointer;
    border-radius: 4px;
    transition: all 0.2s ease;
    display: flex;
    align-items: center;
    gap: 8px;
  }
  .refresh-btn:hover { background: var(--gold-bright); transform: translateY(-1px); }
  .refresh-btn:active { transform: translateY(0); }
  .refresh-btn.loading { opacity: 0.6; pointer-events: none; }
  .refresh-btn svg { width: 16px; height: 16px; }
  .refresh-btn.loading svg { animation: spin 1s linear infinite; }
  @keyframes spin { from { transform: rotate(0deg); } to { transform: rotate(360deg); } }

  /* MAIN SCOREBOARD */
  .scoreboard {
    display: grid;
    grid-template-columns: 1fr auto 1fr;
    gap: 24px;
    margin-bottom: 40px;
    align-items: stretch;
  }
  .team-card {
    background: var(--bg-card);
    border-radius: 12px;
    padding: 32px;
    position: relative;
    overflow: hidden;
    box-shadow: var(--shadow);
    border: 1px solid var(--border);
  }
  .team-card::before {
    content: '';
    position: absolute;
    top: 0; left: 0; right: 0;
    height: 4px;
  }
  .team-hvid::before { background: var(--hvid); }
  .team-rod::before { background: var(--rod); }

  .team-name {
    font-family: var(--display);
    font-size: 32px;
    letter-spacing: 0.05em;
    margin-bottom: 8px;
  }
  .team-hvid .team-name { color: var(--hvid); }
  .team-rod .team-name { color: var(--rod); }
  .team-tagline {
    font-family: var(--mono);
    font-size: 10px;
    color: var(--text-dim);
    text-transform: uppercase;
    letter-spacing: 0.2em;
    margin-bottom: 24px;
  }
  .team-score {
    font-family: var(--display);
    font-size: 140px;
    line-height: 0.85;
    font-weight: 400;
    margin-bottom: 16px;
    letter-spacing: -0.02em;
  }
  .team-hvid .team-score { color: var(--hvid); }
  .team-rod .team-score { color: var(--rod); }
  .team-meta {
    display: flex;
    justify-content: space-between;
    border-top: 1px solid var(--border);
    padding-top: 16px;
    margin-top: 16px;
  }
  .team-meta-item .label {
    font-family: var(--mono);
    font-size: 10px;
    color: var(--text-faint);
    text-transform: uppercase;
    letter-spacing: 0.15em;
    margin-bottom: 4px;
  }
  .team-meta-item .value {
    font-family: var(--display);
    font-size: 24px;
    color: var(--text);
  }

  .vs-divider {
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    min-width: 80px;
  }
  .vs-text {
    font-family: var(--display);
    font-size: 48px;
    color: var(--gold);
    line-height: 1;
  }
  .vs-target {
    font-family: var(--mono);
    font-size: 10px;
    color: var(--text-dim);
    text-transform: uppercase;
    letter-spacing: 0.2em;
    margin-top: 8px;
    text-align: center;
  }
  .vs-target strong { color: var(--gold); font-size: 16px; font-family: var(--display); display: block; margin-top: 4px; }

  /* WIN INDICATOR */
  .winner-banner {
    grid-column: 1 / -1;
    background: linear-gradient(135deg, var(--gold), var(--gold-bright));
    color: var(--bg-dark);
    padding: 16px;
    border-radius: 8px;
    text-align: center;
    font-family: var(--display);
    font-size: 28px;
    letter-spacing: 0.1em;
    margin-bottom: 24px;
    box-shadow: 0 4px 20px rgba(212, 166, 74, 0.3);
    animation: pulse 2s ease-in-out infinite;
  }
  @keyframes pulse {
    0%, 100% { box-shadow: 0 4px 20px rgba(212, 166, 74, 0.3); }
    50% { box-shadow: 0 4px 40px rgba(212, 166, 74, 0.6); }
  }

  /* PROGRESS BAR */
  .progress-section {
    background: var(--bg-card);
    border-radius: 12px;
    padding: 24px 32px;
    margin-bottom: 40px;
    border: 1px solid var(--border);
  }
  .progress-label {
    display: flex;
    justify-content: space-between;
    font-family: var(--mono);
    font-size: 11px;
    color: var(--text-dim);
    text-transform: uppercase;
    letter-spacing: 0.15em;
    margin-bottom: 12px;
  }
  .progress-bar-container {
    position: relative;
    height: 12px;
    background: var(--bg-dark);
    border-radius: 6px;
    overflow: hidden;
    display: flex;
  }
  .progress-hvid {
    background: linear-gradient(90deg, var(--hvid-accent), var(--hvid));
    transition: width 0.6s cubic-bezier(0.4, 0, 0.2, 1);
  }
  .progress-rod {
    background: linear-gradient(90deg, var(--rod), var(--rod-deep));
    transition: width 0.6s cubic-bezier(0.4, 0, 0.2, 1);
    margin-left: auto;
  }
  .progress-target-line {
    position: absolute;
    top: -4px;
    bottom: -4px;
    left: 50%;
    width: 2px;
    background: var(--gold);
    transform: translateX(-50%);
  }
  .progress-target-line::after {
    content: '10,5';
    position: absolute;
    top: -22px;
    left: 50%;
    transform: translateX(-50%);
    font-family: var(--mono);
    font-size: 11px;
    color: var(--gold);
    font-weight: 700;
  }

  /* SECTIONS */
  .section-title {
    font-family: var(--display);
    font-size: 28px;
    letter-spacing: 0.05em;
    color: var(--text);
    margin-bottom: 20px;
    display: flex;
    align-items: center;
    gap: 12px;
  }
  .section-title::after {
    content: '';
    flex: 1;
    height: 1px;
    background: var(--border);
  }

  /* ROUNDS GRID */
  .rounds-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 16px;
    margin-bottom: 40px;
  }
  .round-card {
    background: var(--bg-card);
    border-radius: 8px;
    padding: 20px;
    border: 1px solid var(--border);
  }
  .round-header {
    display: flex;
    justify-content: space-between;
    align-items: baseline;
    margin-bottom: 16px;
    padding-bottom: 12px;
    border-bottom: 1px solid var(--border);
  }
  .round-name {
    font-family: var(--display);
    font-size: 22px;
    color: var(--text);
  }
  .round-format {
    font-family: var(--mono);
    font-size: 9px;
    color: var(--text-dim);
    text-transform: uppercase;
    letter-spacing: 0.15em;
  }
  .round-scores {
    display: flex;
    justify-content: space-around;
    align-items: center;
  }
  .round-team-score {
    text-align: center;
  }
  .round-team-score .label {
    font-family: var(--mono);
    font-size: 10px;
    color: var(--text-faint);
    text-transform: uppercase;
    letter-spacing: 0.15em;
    margin-bottom: 4px;
  }
  .round-team-score .score {
    font-family: var(--display);
    font-size: 40px;
    line-height: 1;
  }
  .round-team-score.hvid .score { color: var(--hvid); }
  .round-team-score.rod .score { color: var(--rod); }
  .round-vs {
    font-family: var(--display);
    color: var(--text-faint);
    font-size: 16px;
  }
  .round-status {
    margin-top: 12px;
    padding-top: 12px;
    border-top: 1px solid var(--border);
    text-align: center;
    font-family: var(--mono);
    font-size: 10px;
    text-transform: uppercase;
    letter-spacing: 0.15em;
  }
  .status-hvid { color: var(--hvid); }
  .status-rod { color: var(--rod); }
  .status-tie { color: var(--gold); }
  .status-pending { color: var(--text-faint); }

  /* MATCH LIST */
  .matches-section { margin-bottom: 40px; }
  .matches-list {
    background: var(--bg-card);
    border-radius: 12px;
    overflow: hidden;
    border: 1px solid var(--border);
  }
  .match-row {
    display: grid;
    grid-template-columns: 60px 1fr 80px 1fr 100px;
    align-items: center;
    padding: 16px 20px;
    border-bottom: 1px solid var(--border);
    gap: 16px;
    transition: background 0.2s ease;
  }
  .match-row:hover { background: var(--bg-card-hover); }
  .match-row:last-child { border-bottom: none; }
  .match-num {
    font-family: var(--display);
    font-size: 18px;
    color: var(--text-dim);
  }
  .match-team {
    display: flex;
    flex-direction: column;
    gap: 2px;
  }
  .match-team.hvid { text-align: right; }
  .match-team .player {
    font-size: 13px;
    font-weight: 500;
    color: var(--text);
  }
  .match-team .player .hcp {
    color: var(--text-dim);
    font-size: 11px;
    font-family: var(--mono);
    margin-left: 4px;
  }
  .match-score {
    text-align: center;
    font-family: var(--display);
    font-size: 24px;
    color: var(--text);
    background: var(--bg-dark);
    padding: 6px 0;
    border-radius: 6px;
  }
  .match-score .sep { color: var(--text-faint); margin: 0 6px; }
  .match-score .hvid-pts.winning { color: var(--hvid); }
  .match-score .rod-pts.winning { color: var(--rod); }
  .match-result {
    font-family: var(--mono);
    font-size: 11px;
    color: var(--text-dim);
    text-align: right;
    text-transform: uppercase;
    letter-spacing: 0.1em;
  }
  .round-divider {
    background: var(--bg-dark);
    padding: 12px 20px;
    font-family: var(--display);
    font-size: 16px;
    letter-spacing: 0.1em;
    color: var(--gold);
    border-bottom: 1px solid var(--border);
  }
  .round-divider .format {
    font-family: var(--mono);
    font-size: 10px;
    color: var(--text-dim);
    text-transform: uppercase;
    letter-spacing: 0.15em;
    margin-left: 12px;
  }

  /* INDIVIDUAL LEADERBOARD */
  .leaderboard-section { margin-bottom: 40px; }
  .leaderboard {
    background: var(--bg-card);
    border-radius: 12px;
    overflow: hidden;
    border: 1px solid var(--border);
  }
  .lb-row {
    display: grid;
    grid-template-columns: 60px 1fr 80px 80px 80px 100px;
    align-items: center;
    padding: 14px 20px;
    border-bottom: 1px solid var(--border);
    gap: 12px;
  }
  .lb-row:last-child { border-bottom: none; }
  .lb-row.header {
    background: var(--bg-dark);
    font-family: var(--mono);
    font-size: 10px;
    color: var(--text-dim);
    text-transform: uppercase;
    letter-spacing: 0.15em;
  }
  .lb-rank {
    font-family: var(--display);
    font-size: 22px;
    color: var(--text-dim);
    text-align: center;
  }
  .lb-rank.medal-1 { color: var(--gold); font-size: 26px; }
  .lb-rank.medal-2 { color: #c0c0c0; font-size: 24px; }
  .lb-rank.medal-3 { color: #cd7f32; font-size: 22px; }
  .lb-name {
    font-weight: 500;
    font-size: 14px;
    color: var(--text);
  }
  .lb-name .friday-only {
    font-family: var(--mono);
    font-size: 9px;
    color: var(--text-faint);
    margin-left: 8px;
    text-transform: uppercase;
    letter-spacing: 0.1em;
  }
  .lb-score {
    text-align: center;
    font-family: var(--mono);
    font-size: 14px;
    color: var(--text-dim);
  }
  .lb-total {
    text-align: center;
    font-family: var(--display);
    font-size: 24px;
    color: var(--gold);
  }
  .lb-row.header .lb-total { font-family: var(--mono); font-size: 10px; color: var(--text-dim); }

  /* COMPETITIONS */
  .competitions {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 16px;
    margin-bottom: 40px;
  }
  .comp-card {
    background: var(--bg-card);
    border-radius: 12px;
    padding: 24px;
    border: 1px solid var(--border);
  }
  .comp-card .icon {
    font-size: 32px;
    margin-bottom: 12px;
  }
  .comp-card .label {
    font-family: var(--mono);
    font-size: 10px;
    color: var(--text-dim);
    text-transform: uppercase;
    letter-spacing: 0.2em;
    margin-bottom: 8px;
  }
  .comp-card .value {
    font-family: var(--display);
    font-size: 24px;
    color: var(--text);
  }
  .comp-card .detail {
    color: var(--text-dim);
    font-size: 13px;
    margin-top: 8px;
  }

  /* LOADING */
  .loading-screen {
    position: fixed;
    inset: 0;
    background: var(--bg-dark);
    display: flex;
    align-items: center;
    justify-content: center;
    z-index: 1000;
    flex-direction: column;
    gap: 16px;
  }
  .loading-screen.hidden { display: none; }
  .loader {
    width: 48px;
    height: 48px;
    border: 3px solid var(--border);
    border-top-color: var(--gold);
    border-radius: 50%;
    animation: spin 1s linear infinite;
  }
  .loading-text {
    font-family: var(--mono);
    font-size: 12px;
    color: var(--text-dim);
    text-transform: uppercase;
    letter-spacing: 0.2em;
  }

  .error-banner {
    background: rgba(214, 50, 64, 0.1);
    border: 1px solid var(--rod);
    color: var(--text);
    padding: 16px;
    border-radius: 8px;
    margin-bottom: 24px;
    font-size: 14px;
    display: none;
  }
  .error-banner.visible { display: block; }

  /* RESPONSIVE */
  @media (max-width: 900px) {
    body { padding: 16px; }
    .title h1 { font-size: 36px; }
    .header { flex-direction: column; gap: 16px; align-items: flex-start; }
    .scoreboard { grid-template-columns: 1fr; gap: 12px; }
    .team-score { font-size: 90px; }
    .vs-divider { flex-direction: row; gap: 16px; padding: 8px 0; }
    .rounds-grid { grid-template-columns: 1fr; }
    .match-row { grid-template-columns: 40px 1fr 70px 1fr; padding: 12px; gap: 8px; }
    .match-row .match-result { display: none; }
    .match-team .player { font-size: 11px; }
    .lb-row { grid-template-columns: 40px 1fr 60px 80px; padding: 10px; gap: 8px; }
    .lb-row .lb-r2, .lb-row .lb-r3 { display: none; }
    .competitions { grid-template-columns: 1fr; }
  }

  /* ANIMATIONS */
  @keyframes fadeIn {
    from { opacity: 0; transform: translateY(10px); }
    to { opacity: 1; transform: translateY(0); }
  }
  .fade-in { animation: fadeIn 0.4s ease forwards; }

  /* SCORE PULSE on update */
  @keyframes scorePulse {
    0%, 100% { transform: scale(1); }
    50% { transform: scale(1.05); }
  }
  .score-updated { animation: scorePulse 0.5s ease; }
</style>
</head>
<body>

<div class="loading-screen" id="loadingScreen">
  <div class="loader"></div>
  <div class="loading-text">Henter live data…</div>
</div>

<div class="container">

  <!-- HEADER -->
  <div class="header">
    <div class="title">
      <h1>JAMMERBUGT <span class="accent">OPEN</span> 2026</h1>
      <div class="subtitle">Live Dashboard · Hvidt vs Rødt</div>
    </div>
    <div class="header-right">
      <div class="last-update">
        Sidst opdateret<br>
        <strong id="lastUpdate">—</strong>
      </div>
      <button class="refresh-btn" onclick="loadData()" id="refreshBtn">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3">
          <path d="M1 4v6h6M23 20v-6h-6"/>
          <path d="M20.49 9A9 9 0 005.64 5.64L1 10m22 4l-4.64 4.36A9 9 0 013.51 15"/>
        </svg>
        Opdater
      </button>
    </div>
  </div>

  <div class="error-banner" id="errorBanner"></div>

  <!-- WINNER BANNER (hidden by default) -->
  <div class="winner-banner" id="winnerBanner" style="display: none;">
    🏆 <span id="winnerText"></span> 🏆
  </div>

  <!-- MAIN SCOREBOARD -->
  <div class="scoreboard">
    <div class="team-card team-hvid">
      <div class="team-name">HVIDT HOLD</div>
      <div class="team-tagline">The Pale Riders</div>
      <div class="team-score" id="scoreHvid">0</div>
      <div class="team-meta">
        <div class="team-meta-item">
          <div class="label">Matcher vundet</div>
          <div class="value" id="winsHvid">0</div>
        </div>
        <div class="team-meta-item">
          <div class="label">Uafgjort</div>
          <div class="value" id="tiesHvid">0</div>
        </div>
      </div>
    </div>

    <div class="vs-divider">
      <div class="vs-text">VS</div>
      <div class="vs-target">Først til<strong>10,5</strong></div>
    </div>

    <div class="team-card team-rod">
      <div class="team-name">RØDT HOLD</div>
      <div class="team-tagline">Red Devils</div>
      <div class="team-score" id="scoreRod">0</div>
      <div class="team-meta">
        <div class="team-meta-item">
          <div class="label">Matcher vundet</div>
          <div class="value" id="winsRod">0</div>
        </div>
        <div class="team-meta-item">
          <div class="label">Uafgjort</div>
          <div class="value" id="tiesRod">0</div>
        </div>
      </div>
    </div>
  </div>

  <!-- PROGRESS BAR -->
  <div class="progress-section">
    <div class="progress-label">
      <span>VEJEN TIL POKALEN</span>
      <span><span id="progressTotal">0</span> / 21 point spillet</span>
    </div>
    <div class="progress-bar-container">
      <div class="progress-hvid" id="progressHvid" style="width: 0%"></div>
      <div class="progress-rod" id="progressRod" style="width: 0%"></div>
      <div class="progress-target-line"></div>
    </div>
  </div>

  <!-- ROUNDS -->
  <h2 class="section-title">Runder</h2>
  <div class="rounds-grid">
    <div class="round-card">
      <div class="round-header">
        <div class="round-name">Runde 1</div>
        <div class="round-format">Fre · High/Low</div>
      </div>
      <div class="round-scores">
        <div class="round-team-score hvid">
          <div class="label">Hvid</div>
          <div class="score" id="r1Hvid">0</div>
        </div>
        <div class="round-vs">—</div>
        <div class="round-team-score rod">
          <div class="label">Rød</div>
          <div class="score" id="r1Rod">0</div>
        </div>
      </div>
      <div class="round-status" id="r1Status">Afventer</div>
    </div>

    <div class="round-card">
      <div class="round-header">
        <div class="round-name">Runde 2</div>
        <div class="round-format">Lør · 4-Ball Stableford</div>
      </div>
      <div class="round-scores">
        <div class="round-team-score hvid">
          <div class="label">Hvid</div>
          <div class="score" id="r2Hvid">0</div>
        </div>
        <div class="round-vs">—</div>
        <div class="round-team-score rod">
          <div class="label">Rød</div>
          <div class="score" id="r2Rod">0</div>
        </div>
      </div>
      <div class="round-status" id="r2Status">Afventer</div>
    </div>

    <div class="round-card">
      <div class="round-header">
        <div class="round-name">Runde 3</div>
        <div class="round-format">Lør · Singler (9 huller)</div>
      </div>
      <div class="round-scores">
        <div class="round-team-score hvid">
          <div class="label">Hvid</div>
          <div class="score" id="r3Hvid">0</div>
        </div>
        <div class="round-vs">—</div>
        <div class="round-team-score rod">
          <div class="label">Rød</div>
          <div class="score" id="r3Rod">0</div>
        </div>
      </div>
      <div class="round-status" id="r3Status">Afventer</div>
    </div>
  </div>

  <!-- ALL MATCHES -->
  <h2 class="section-title">Alle Matcher</h2>
  <div class="matches-section">
    <div class="matches-list" id="matchesList">
      <!-- Filled by JS -->
    </div>
  </div>

  <!-- INDIVIDUAL LEADERBOARD -->
  <h2 class="section-title">Individuel Stableford-stilling</h2>
  <div class="leaderboard-section">
    <div class="leaderboard" id="leaderboard">
      <div class="lb-row header">
        <div class="lb-rank">#</div>
        <div class="lb-name">Spiller</div>
        <div class="lb-score lb-r1">R1</div>
        <div class="lb-score lb-r2">R2</div>
        <div class="lb-score lb-r3">R3</div>
        <div class="lb-total">Total</div>
      </div>
      <!-- Filled by JS -->
    </div>
  </div>

  <!-- COMPETITIONS -->
  <h2 class="section-title">Indlagte konkurrencer</h2>
  <div class="competitions">
    <div class="comp-card">
      <div class="icon">🎯</div>
      <div class="label">Tættest hullet</div>
      <div class="value">Hul 3 · 9 · 10</div>
    </div>
    <div class="comp-card">
      <div class="icon">🚀</div>
      <div class="label">Længste drive</div>
      <div class="value">Hul 5</div>
      <div class="detail">Tee shot skal lande på fairway</div>
    </div>
  </div>

</div>

<script>
const CSV_URL = 'https://docs.google.com/spreadsheets/d/e/2PACX-1vRT0vgXXFT_ZV2MGok6S1wZTbyEqLpa4-bBKqlBH1abwHeiw2OpjG7Zw9ZDYSMRYjX1ZcDHDBIbaMU1/pub?gid=892759110&single=true&output=csv';

// CORS-proxies (used to bypass browser CORS restrictions on local files)
const PROXIES = [
  url => 'https://corsproxy.io/?' + encodeURIComponent(url),
  url => 'https://api.allorigins.win/raw?url=' + encodeURIComponent(url),
  url => url  // Direct attempt as last resort
];

// Toggle debug by adding ?debug=1 to URL
const DEBUG = new URLSearchParams(window.location.search).has('debug');

// Parse CSV with proper quote handling
function parseCSV(text) {
  const rows = [];
  let row = [];
  let cell = '';
  let inQuotes = false;

  for (let i = 0; i < text.length; i++) {
    const ch = text[i];
    const next = text[i + 1];

    if (inQuotes) {
      if (ch === '"' && next === '"') { cell += '"'; i++; }
      else if (ch === '"') { inQuotes = false; }
      else { cell += ch; }
    } else {
      if (ch === '"') { inQuotes = true; }
      else if (ch === ',') { row.push(cell); cell = ''; }
      else if (ch === '\n' || ch === '\r') {
        if (ch === '\r' && next === '\n') i++;
        row.push(cell); cell = '';
        rows.push(row); row = [];
      } else { cell += ch; }
    }
  }
  if (cell.length || row.length) { row.push(cell); rows.push(row); }
  return rows;
}

// Convert Danish decimal "0,5" to number 0.5. Returns null for empty/invalid.
function parseDanishNumber(str) {
  if (str === undefined || str === null) return null;
  const trimmed = String(str).trim();
  if (trimmed === '') return null;
  const cleaned = trimmed.replace(/\./g, '').replace(',', '.');
  // Try simpler: just replace , with .
  const simple = trimmed.replace(',', '.');
  const num = parseFloat(simple);
  return isNaN(num) ? null : num;
}

function showError(msg) {
  const banner = document.getElementById('errorBanner');
  banner.innerHTML = msg;
  banner.classList.add('visible');
}
function hideError() {
  document.getElementById('errorBanner').classList.remove('visible');
}

function setText(id, text) {
  const el = document.getElementById(id);
  if (el) el.textContent = text;
}

function formatNum(n) {
  if (n === null || n === undefined) return '–';
  const fixed = Math.round(n * 10) / 10;
  return String(fixed).replace('.', ',');
}

function formatScore(n) {
  if (n === null || n === undefined) return '0';
  return formatNum(n);
}

function processData(rows) {
  const matches = [];
  let currentRound = null;
  let currentFormat = null;
  let leaderboardStart = -1;

  // First pass: find matches and round contexts
  for (let i = 0; i < rows.length; i++) {
    const row = rows[i];
    const first = (row[0] || '').trim();
    const rowText = row.join(' ').toLowerCase();

    // Detect round headers - search whole row
    if (rowText.includes('runde 1') && !rowText.includes('individuelle')) currentRound = 1;
    else if (rowText.includes('runde 2') && !rowText.includes('individuelle')) currentRound = 2;
    else if (rowText.includes('runde 3') && !rowText.includes('individuelle')) currentRound = 3;

    // Detect format row
    if (first.toLowerCase().startsWith('matchform')) {
      currentFormat = (row[1] || '').trim();
    }

    // Match rows: "Match 1", "Match 2", etc.
    const matchMatch = first.match(/^Match\s+(\d+)/i);
    if (matchMatch && currentRound) {
      const matchNum = parseInt(matchMatch[1]);
      const hvidPlayers = (row[1] || '').trim();
      const rodPlayers = (row[2] || '').trim();
      const startHole = (row[3] || '').trim();
      const pointHvid = parseDanishNumber(row[4]);
      const pointRod = parseDanishNumber(row[5]);
      const result = (row[6] || '').trim();

      matches.push({
        round: currentRound,
        format: currentFormat,
        num: matchNum,
        hvid: hvidPlayers,
        rod: rodPlayers,
        startHole,
        pointHvid,
        pointRod,
        result
      });
    }

    // Mark leaderboard section start
    if (rowText.includes('individuelle stableford')) {
      leaderboardStart = i;
    }
  }

  // Second pass: find leaderboard
  const leaderboard = [];
  if (leaderboardStart >= 0) {
    for (let i = leaderboardStart + 1; i < rows.length; i++) {
      const row = rows[i];
      // Player name should be in column 2 (index 2). Look for non-empty.
      let name = (row[2] || '').trim();
      // Skip if it's another header
      if (!name) continue;
      if (name.toLowerCase().includes('stableford')) continue;

      const r1 = parseDanishNumber(row[3]);
      const r2 = parseDanishNumber(row[4]);
      const r3 = parseDanishNumber(row[5]);
      const total = parseDanishNumber(row[6]);

      // Only add if there's actual data (at least one number)
      if (r1 !== null || r2 !== null || r3 !== null || total !== null) {
        leaderboard.push({ name, r1, r2, r3, total });
      }
    }
  }

  return { matches, leaderboard };
}

function calculateScores(matches) {
  const round = { 1: { h: 0, r: 0 }, 2: { h: 0, r: 0 }, 3: { h: 0, r: 0 } };
  let totalPlayed = 0;
  let winsHvid = 0, winsRod = 0, ties = 0;

  matches.forEach(m => {
    if (m.pointHvid !== null) round[m.round].h += m.pointHvid;
    if (m.pointRod !== null) round[m.round].r += m.pointRod;
    if (m.pointHvid !== null && m.pointRod !== null) {
      totalPlayed += m.pointHvid + m.pointRod;
      if (m.pointHvid > m.pointRod) winsHvid++;
      else if (m.pointRod > m.pointHvid) winsRod++;
      else if (m.pointHvid > 0) ties++;
    }
  });

  return {
    round,
    totalHvid: round[1].h + round[2].h + round[3].h,
    totalRod: round[1].r + round[2].r + round[3].r,
    totalPlayed,
    winsHvid,
    winsRod,
    ties
  };
}

function render(data) {
  const { matches, leaderboard } = data;
  const scores = calculateScores(matches);

  if (DEBUG) {
    console.log('=== DEBUG ===');
    console.log('Matches found:', matches.length);
    console.log('Matches:', matches);
    console.log('Leaderboard rows:', leaderboard.length);
    console.log('Leaderboard:', leaderboard);
    console.log('Scores:', scores);
  }

  // Show debug info if no matches found
  if (matches.length === 0) {
    showError('⚠️ Ingen matcher fundet i CSV-data. Tilføj <code>?debug=1</code> til URL\'en og åbn browserens konsol (F12) for at se hvad der hentes.');
  }

  // Animate score updates
  const prevHvid = parseFloat(document.getElementById('scoreHvid').dataset.value || 0);
  const prevRod = parseFloat(document.getElementById('scoreRod').dataset.value || 0);

  setText('scoreHvid', formatScore(scores.totalHvid));
  setText('scoreRod', formatScore(scores.totalRod));
  document.getElementById('scoreHvid').dataset.value = scores.totalHvid;
  document.getElementById('scoreRod').dataset.value = scores.totalRod;

  if (scores.totalHvid !== prevHvid) {
    document.getElementById('scoreHvid').classList.add('score-updated');
    setTimeout(() => document.getElementById('scoreHvid').classList.remove('score-updated'), 500);
  }
  if (scores.totalRod !== prevRod) {
    document.getElementById('scoreRod').classList.add('score-updated');
    setTimeout(() => document.getElementById('scoreRod').classList.remove('score-updated'), 500);
  }

  setText('winsHvid', scores.winsHvid);
  setText('winsRod', scores.winsRod);
  setText('tiesHvid', scores.ties);
  setText('tiesRod', scores.ties);

  // Round scores
  setText('r1Hvid', formatScore(scores.round[1].h));
  setText('r1Rod', formatScore(scores.round[1].r));
  setText('r2Hvid', formatScore(scores.round[2].h));
  setText('r2Rod', formatScore(scores.round[2].r));
  setText('r3Hvid', formatScore(scores.round[3].h));
  setText('r3Rod', formatScore(scores.round[3].r));

  // Round status
  [1, 2, 3].forEach(r => {
    const el = document.getElementById(`r${r}Status`);
    const { h, r: rod } = scores.round[r];
    if (h === 0 && rod === 0) {
      el.textContent = 'Afventer';
      el.className = 'round-status status-pending';
    } else if (h > rod) {
      el.textContent = `Hvidt fører med ${formatNum(h - rod)}`;
      el.className = 'round-status status-hvid';
    } else if (rod > h) {
      el.textContent = `Rødt fører med ${formatNum(rod - h)}`;
      el.className = 'round-status status-rod';
    } else {
      el.textContent = 'Uafgjort';
      el.className = 'round-status status-tie';
    }
  });

  // Progress bar
  const maxPoints = 21;
  const totalPoints = scores.totalHvid + scores.totalRod;
  setText('progressTotal', formatScore(totalPoints));
  const denominator = Math.max(maxPoints, totalPoints, 1);
  const hvidPct = (scores.totalHvid / denominator) * 100;
  const rodPct = (scores.totalRod / denominator) * 100;
  document.getElementById('progressHvid').style.width = hvidPct + '%';
  document.getElementById('progressRod').style.width = rodPct + '%';

  // Winner banner
  const winnerBanner = document.getElementById('winnerBanner');
  if (scores.totalHvid >= 10.5) {
    document.getElementById('winnerText').textContent = 'HVIDT HOLD VINDER POKALEN';
    winnerBanner.style.display = 'block';
  } else if (scores.totalRod >= 10.5) {
    document.getElementById('winnerText').textContent = 'RØDT HOLD VINDER POKALEN';
    winnerBanner.style.display = 'block';
  } else {
    winnerBanner.style.display = 'none';
  }

  // Render matches
  const matchesContainer = document.getElementById('matchesList');
  matchesContainer.innerHTML = '';

  if (matches.length === 0) {
    matchesContainer.innerHTML = '<div style="padding: 40px; text-align: center; color: var(--text-dim);">Ingen matcher hentet endnu</div>';
  } else {
    let lastRound = null;
    matches.forEach(m => {
      if (m.round !== lastRound) {
        const divider = document.createElement('div');
        divider.className = 'round-divider';
        const roundName = m.round === 1 ? 'RUNDE 1 — FREDAG' : m.round === 2 ? 'RUNDE 2 — LØRDAG FORMIDDAG' : 'RUNDE 3 — LØRDAG EFTERMIDDAG';
        divider.innerHTML = `${roundName}<span class="format">${m.format || ''}</span>`;
        matchesContainer.appendChild(divider);
        lastRound = m.round;
      }

      const hasScore = m.pointHvid !== null || m.pointRod !== null;
      const hvidWin = hasScore && m.pointHvid > m.pointRod;
      const rodWin = hasScore && m.pointRod > m.pointHvid;

      const row = document.createElement('div');
      row.className = 'match-row';
      row.innerHTML = `
        <div class="match-num">M${m.num}</div>
        <div class="match-team hvid">
          <div class="player">${m.hvid || '<em style="color:var(--text-faint)">Afventer</em>'}</div>
        </div>
        <div class="match-score">
          <span class="hvid-pts ${hvidWin ? 'winning' : ''}">${hasScore ? formatScore(m.pointHvid) : '–'}</span>
          <span class="sep">·</span>
          <span class="rod-pts ${rodWin ? 'winning' : ''}">${hasScore ? formatScore(m.pointRod) : '–'}</span>
        </div>
        <div class="match-team rod">
          <div class="player">${m.rod || '<em style="color:var(--text-faint)">Afventer</em>'}</div>
        </div>
        <div class="match-result">${m.result || (m.startHole ? 'Hul ' + m.startHole : '')}</div>
      `;
      matchesContainer.appendChild(row);
    });
  }

  // Render leaderboard
  const lb = document.getElementById('leaderboard');
  const headerRow = lb.querySelector('.lb-row.header');
  lb.innerHTML = '';
  if (headerRow) lb.appendChild(headerRow);

  if (leaderboard.length === 0) {
    const empty = document.createElement('div');
    empty.style.cssText = 'padding: 40px; text-align: center; color: var(--text-dim);';
    empty.textContent = 'Ingen individuelle scores hentet endnu';
    lb.appendChild(empty);
  } else {
    const sorted = [...leaderboard].sort((a, b) => (b.total || 0) - (a.total || 0));
    sorted.forEach((p, idx) => {
      const rank = idx + 1;
      const medalClass = rank <= 3 ? `medal-${rank}` : '';
      const rankDisplay = rank === 1 ? '🥇' : rank === 2 ? '🥈' : rank === 3 ? '🥉' : rank;
      const isFridayOnly = p.name.toLowerCase().includes('fredag');
      const cleanName = p.name.replace(/\s*\(kun fredag\)\s*/i, '');

      const row = document.createElement('div');
      row.className = 'lb-row';
      row.innerHTML = `
        <div class="lb-rank ${medalClass}">${rankDisplay}</div>
        <div class="lb-name">${cleanName}${isFridayOnly ? '<span class="friday-only">Kun fre</span>' : ''}</div>
        <div class="lb-score lb-r1">${p.r1 !== null ? formatScore(p.r1) : '–'}</div>
        <div class="lb-score lb-r2">${p.r2 !== null ? formatScore(p.r2) : '–'}</div>
        <div class="lb-score lb-r3">${p.r3 !== null ? formatScore(p.r3) : '–'}</div>
        <div class="lb-total">${p.total !== null ? formatScore(p.total) : '–'}</div>
      `;
      lb.appendChild(row);
    });
  }

  // Update timestamp
  const now = new Date();
  const time = now.toLocaleTimeString('da-DK', { hour: '2-digit', minute: '2-digit', second: '2-digit' });
  setText('lastUpdate', time);
}

async function loadData() {
  const btn = document.getElementById('refreshBtn');
  btn.classList.add('loading');
  hideError();

  const csvUrlWithBuster = CSV_URL + '&_=' + Date.now();
  let lastError = null;
  let text = null;

  // Try each proxy until one works
  for (let i = 0; i < PROXIES.length; i++) {
    const proxyUrl = PROXIES[i](csvUrlWithBuster);
    try {
      if (DEBUG) console.log(`Trying proxy ${i + 1}: ${proxyUrl}`);
      const response = await fetch(proxyUrl);
      if (!response.ok) throw new Error('HTTP ' + response.status);
      text = await response.text();
      // Sanity check: must contain at least the word "Match"
      if (text && text.includes('Match')) {
        if (DEBUG) console.log(`Proxy ${i + 1} succeeded`);
        break;
      } else {
        throw new Error('Indholdet ser ikke ud til at være rigtigt CSV');
      }
    } catch (err) {
      lastError = err;
      if (DEBUG) console.warn(`Proxy ${i + 1} failed:`, err.message);
      text = null;
    }
  }

  if (!text) {
    showError('Kunne ikke hente data: ' + (lastError ? lastError.message : 'ukendt fejl') + '. Tjek at arket er publiceret som CSV.');
    document.getElementById('loadingScreen').classList.add('hidden');
    btn.classList.remove('loading');
    return;
  }

  try {
    if (DEBUG) {
      console.log('=== RAW CSV (first 2000 chars) ===');
      console.log(text.substring(0, 2000));
    }

    const rows = parseCSV(text);

    if (DEBUG) {
      console.log('=== PARSED ROWS (first 60) ===');
      rows.slice(0, 60).forEach((r, i) => console.log(i, r));
    }

    const data = processData(rows);
    render(data);
    document.getElementById('loadingScreen').classList.add('hidden');
  } catch (err) {
    console.error(err);
    showError('Fejl ved behandling af data: ' + err.message);
    document.getElementById('loadingScreen').classList.add('hidden');
  } finally {
    btn.classList.remove('loading');
  }
}

// Initial load
loadData();
</script>
